# ============================================
# MULTI-TENANT CADDYFILE (NO SSL/TLS)
# DNS resolution: Caddy uses Docker container names
# ============================================
# {
# 	servers {
# 		trusted_proxies static private_ranges
# 	}
# }
# {
# 	# Disable automatic HTTPS completely
# 	auto_https off
# }

# ========== SUBDOMAIN TENANTS ==========
:9852 {
	# Enable debug logging
	log {
		output stdout
		level DEBUG
	}

	# Handle exact /app path
	handle /app {
		reverse_proxy localhost:9000 {
			header_up X-Store-Id "store_01KR1FSSPQ60MTNTDSKHBFT9XX"
		}
	}

	# Explicitly match authentication paths
	handle /auth/* {
		reverse_proxy localhost:9000 {
			# Add X-Store-Id header from subdomain (or default value)
			header_up X-Store-Id "store_01KR1FSSPQ60MTNTDSKHBFT9XX"
		}
	}

	# Match app paths
	handle /app/* {
		reverse_proxy localhost:9000 {
			# Add X-Store-Id header from subdomain
			header_up X-Store-Id "store_01KR1FSSPQ60MTNTDSKHBFT9XX"
		}
	}

	# Match admin paths
	handle /admin/* {
		reverse_proxy localhost:9000 {
			# Add X-Store-Id header from subdomain
			header_up X-Store-Id "store_01KR1FSSPQ60MTNTDSKHBFT9XX"
		}
	}

	# Match admin paths
	handle {
		reverse_proxy localhost:8000 {
			# Add X-Store-Id header from subdomain
			header_up X-Store-Id "store_01KR1FSSPQ60MTNTDSKHBFT9XX"
		}
	}
}

:5000 {
	reverse_proxy registry:5000
}

